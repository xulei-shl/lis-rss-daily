<%- include('layout', { pageTitle: pageTitle, pageStyles: '<link rel="stylesheet" href="/css/pages/logs.css">' , body: `
  <div class="logs-page">
  <div class="section-header">
    <h2>流程日志</h2>
  </div>

  <div class="logs-tabs">
    <button class="logs-tab active" data-tab="all">全部流程</button>
    <button class="logs-tab" data-tab="rss">RSS 抓取</button>
    <button class="logs-tab" data-tab="crawl">期刊爬取</button>
    <button class="logs-tab" data-tab="filter">过滤日志</button>
    <button class="logs-tab" data-tab="process">后处理</button>
  </div>

  <div class="logs-tab-panel active" data-panel="all">
    <table class="logs-table" id="unifiedTable">
      <thead>
        <tr>
          <th class="expand-cell"></th>
          <th>流程</th>
          <th>概要</th>
          <th>状态</th>
          <th>时间</th>
        </tr>
      </thead>
      <tbody id="unifiedBody"></tbody>
    </table>
    <div class="empty-state" id="unifiedEmpty">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p>暂无流程日志</p>
    </div>
    <div class="pagination" id="unifiedPagination"></div>
  </div>

  <div class="logs-tab-panel" data-panel="rss">
    <div class="panel-filter logs-filter-bar">
      <div class="filter-group">
        <label>结果:</label>
        <select id="rssStatusFilter" class="filter-select">
          <option value="">全部</option>
          <option value="success">成功</option>
          <option value="partial">部分成功</option>
          <option value="failed">失败</option>
        </select>
      </div>
      <div class="filter-group">
        <label>执行:</label>
        <select id="rssScheduleFilter" class="filter-select">
          <option value="">全部</option>
          <option value="scheduled">定时</option>
          <option value="manual">手动</option>
        </select>
      </div>
    </div>
    <table class="logs-table" id="rssTable">
      <thead>
        <tr>
          <th class="expand-cell"></th>
          <th>来源</th>
          <th>结果</th>
          <th>新增/总数</th>
          <th>耗时</th>
          <th>时间</th>
        </tr>
      </thead>
      <tbody id="rssBody"></tbody>
    </table>
    <div class="empty-state" id="rssEmpty">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p>暂无 RSS 抓取日志</p>
    </div>
    <div class="pagination" id="rssPagination"></div>
  </div>

  <div class="logs-tab-panel" data-panel="crawl">
    <div class="panel-filter logs-filter-bar">
      <div class="filter-group">
        <label>结果:</label>
        <select id="crawlResultFilter" class="filter-select">
          <option value="">全部</option>
          <option value="success">成功</option>
          <option value="partial">部分成功</option>
          <option value="failed">失败</option>
        </select>
      </div>
    </div>
    <table class="logs-table" id="crawlTable">
      <thead>
        <tr>
          <th class="expand-cell"></th>
          <th>期刊</th>
          <th>期次</th>
          <th>结果</th>
          <th>新增/总数</th>
          <th>耗时</th>
          <th>时间</th>
        </tr>
      </thead>
      <tbody id="crawlBody"></tbody>
    </table>
    <div class="empty-state" id="crawlEmpty">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p>暂无爬取日志</p>
    </div>
    <div class="pagination" id="crawlPagination"></div>
  </div>

  <div class="logs-tab-panel" data-panel="filter">
    <div class="panel-filter logs-filter-bar">
      <div class="filter-group">
        <label>领域:</label>
        <select id="domainFilter" class="filter-select">
          <option value="">全部领域</option>
        </select>
      </div>
      <div class="filter-group">
        <label>结果:</label>
        <select id="resultFilter" class="filter-select">
          <option value="">全部</option>
          <option value="passed">通过</option>
          <option value="rejected">拒绝</option>
        </select>
      </div>
    </div>
    <table class="logs-table" id="filterTable">
      <thead>
        <tr>
          <th class="expand-cell"></th>
          <th>文章</th>
          <th>领域</th>
          <th>结果</th>
          <th>相关性</th>
          <th>原因</th>
          <th>时间</th>
        </tr>
      </thead>
      <tbody id="filterBody"></tbody>
    </table>
    <div class="empty-state" id="filterEmpty">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p>暂无过滤日志</p>
    </div>
    <div class="pagination" id="filterPagination"></div>
  </div>

  <div class="logs-tab-panel" data-panel="process">
    <div class="panel-filter logs-filter-bar">
      <div class="filter-group">
        <label>阶段:</label>
        <select id="processStageFilter" class="filter-select">
          <option value="">全部</option>
          <option value="markdown">内容清洗</option>
          <option value="translate">翻译</option>
          <option value="vector">向量化</option>
          <option value="related">相关文章</option>
          <option value="pipeline_complete">流程完成</option>
        </select>
      </div>
      <div class="filter-group">
        <label>状态:</label>
        <select id="processStatusFilter" class="filter-select">
          <option value="">全部</option>
          <option value="processing">处理中</option>
          <option value="completed">完成</option>
          <option value="failed">失败</option>
          <option value="skipped">跳过</option>
        </select>
      </div>
    </div>
    <table class="logs-table" id="processTable">
      <thead>
        <tr>
          <th class="expand-cell"></th>
          <th>文章/阶段</th>
          <th>状态</th>
          <th>耗时</th>
          <th>来源</th>
          <th>时间</th>
        </tr>
      </thead>
      <tbody id="processBody"></tbody>
    </table>
    <div class="empty-state" id="processEmpty">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p>暂无后处理日志</p>
    </div>
    <div class="pagination" id="processPagination"></div>
  </div>
  </div>

  <script>
    (() => {
      const pageSize = 20;
      const state = {
        currentTab: 'all',
        tabs: {
          all: { page: 1, totalPages: 1 },
          rss: { page: 1, totalPages: 1 },
          crawl: { page: 1, totalPages: 1 },
          filter: { page: 1, totalPages: 1 },
          process: { page: 1, totalPages: 1 },
        },
        filters: {
          domainId: '',
          filterResult: '',
          rssStatus: '',
          rssSchedule: '',
          crawlStatus: '',
          processStage: '',
          processStatus: '',
        },
      };

      let domains = [];

      document.addEventListener('DOMContentLoaded', () => {
        initTabs();
        initFilterControls();
        loadDomains();
        reloadAllTabs();
      });

      function initTabs() {
        const tabs = document.querySelectorAll('.logs-tab');
        tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const target = tab.dataset.tab;
            if (!target || target === state.currentTab) return;
            state.currentTab = target;
            tabs.forEach((btn) => btn.classList.toggle('active', btn.dataset.tab === target));
            document.querySelectorAll('.logs-tab-panel').forEach((panel) => {
              panel.classList.toggle('active', panel.dataset.panel === target);
            });
          });
        });
      }

      function initFilterControls() {
        const domainSelect = document.getElementById('domainFilter');
        if (domainSelect) {
          domainSelect.addEventListener('change', () => {
            state.filters.domainId = domainSelect.value;
            loadFilterLogs(1);
          });
        }

        const filterResult = document.getElementById('resultFilter');
        if (filterResult) {
          filterResult.addEventListener('change', () => {
            state.filters.filterResult = filterResult.value;
            loadFilterLogs(1);
          });
        }

        const rssStatus = document.getElementById('rssStatusFilter');
        if (rssStatus) {
          rssStatus.addEventListener('change', () => {
            state.filters.rssStatus = rssStatus.value;
            loadRssLogs(1);
          });
        }

        const rssSchedule = document.getElementById('rssScheduleFilter');
        if (rssSchedule) {
          rssSchedule.addEventListener('change', () => {
            state.filters.rssSchedule = rssSchedule.value;
            loadRssLogs(1);
          });
        }

        const crawlResult = document.getElementById('crawlResultFilter');
        if (crawlResult) {
          crawlResult.addEventListener('change', () => {
            state.filters.crawlStatus = crawlResult.value;
            loadCrawlLogs(1);
          });
        }

        const processStage = document.getElementById('processStageFilter');
        if (processStage) {
          processStage.addEventListener('change', () => {
            state.filters.processStage = processStage.value;
            loadProcessLogs(1);
          });
        }

        const processStatus = document.getElementById('processStatusFilter');
        if (processStatus) {
          processStatus.addEventListener('change', () => {
            state.filters.processStatus = processStatus.value;
            loadProcessLogs(1);
          });
        }
      }

      function reloadAllTabs() {
        Object.keys(state.tabs).forEach((key) => {
          state.tabs[key].page = 1;
        });
        loadUnifiedLogs(1);
        loadRssLogs(1);
        loadCrawlLogs(1);
        loadFilterLogs(1);
        loadProcessLogs(1);
      }

      async function loadDomains() {
        try {
          const res = await fetch('/api/topic-domains?isActive=true');
          const data = await res.json();
          domains = data.domains || [];
          const select = document.getElementById('domainFilter');
          if (select) {
            select.innerHTML = '<option value="">全部领域</option>';
            domains.forEach((domain) => {
              const option = document.createElement('option');
              option.value = domain.id;
              option.textContent = domain.name;
              select.appendChild(option);
            });
          }
        } catch (err) {
          console.error('Failed to load domains', err);
          toast.error('加载领域列表失败：' + (err.message || '网络错误'));
        }
      }

      async function loadUnifiedLogs(page = 1) {
        try {
          const params = buildParams(page);
          const data = await fetchJson('/api/logs/unified', params);
          state.tabs.all.page = data.page || 1;
          state.tabs.all.totalPages = data.totalPages || 1;
          renderUnifiedLogs(data.logs || []);
          renderPagination('unifiedPagination', state.tabs.all.page, state.tabs.all.totalPages, 'all');
        } catch (err) {
          console.error(err);
          toast.error('加载流程日志失败：' + (err.message || '网络错误'));
          showEmptyState('unifiedTable', 'unifiedEmpty');
        }
      }

      async function loadRssLogs(page = 1) {
        try {
          const params = buildParams(page);
          if (state.filters.rssStatus) params.status = state.filters.rssStatus;
          if (state.filters.rssSchedule === 'scheduled') params.isScheduled = 'true';
          if (state.filters.rssSchedule === 'manual') params.isScheduled = 'false';
          const data = await fetchJson('/api/logs/rss-fetch', params);
          state.tabs.rss.page = data.page || 1;
          state.tabs.rss.totalPages = data.totalPages || 1;
          renderRssLogs(data.logs || []);
          renderPagination('rssPagination', state.tabs.rss.page, state.tabs.rss.totalPages, 'rss');
        } catch (err) {
          console.error(err);
          toast.error('加载 RSS 抓取日志失败：' + (err.message || '网络错误'));
          showEmptyState('rssTable', 'rssEmpty');
        }
      }

      async function loadCrawlLogs(page = 1) {
        try {
          const params = buildParams(page);
          if (state.filters.crawlStatus) params.result = state.filters.crawlStatus;
          const data = await fetchJson('/api/logs/crawl', params);
          state.tabs.crawl.page = data.page || 1;
          state.tabs.crawl.totalPages = data.totalPages || 1;
          renderCrawlLogs(data.logs || []);
          renderPagination('crawlPagination', state.tabs.crawl.page, state.tabs.crawl.totalPages, 'crawl');
        } catch (err) {
          console.error(err);
          toast.error('加载爬取日志失败：' + (err.message || '网络错误'));
          showEmptyState('crawlTable', 'crawlEmpty');
        }
      }

      async function loadFilterLogs(page = 1) {
        try {
          const params = buildParams(page);
          if (state.filters.domainId) params.domainId = state.filters.domainId;
          if (state.filters.filterResult) params.isPassed = state.filters.filterResult === 'passed' ? 'true' : 'false';
          const data = await fetchJson('/api/logs/filter', params);
          state.tabs.filter.page = data.page || 1;
          state.tabs.filter.totalPages = data.totalPages || 1;
          renderFilterLogs(data.logs || []);
          renderPagination('filterPagination', state.tabs.filter.page, state.tabs.filter.totalPages, 'filter');
        } catch (err) {
          console.error(err);
          toast.error('加载过滤日志失败：' + (err.message || '网络错误'));
          showEmptyState('filterTable', 'filterEmpty');
        }
      }

      async function loadProcessLogs(page = 1) {
        try {
          const params = buildParams(page);
          if (state.filters.processStage) params.stage = state.filters.processStage;
          if (state.filters.processStatus) params.status = state.filters.processStatus;
          const data = await fetchJson('/api/logs/process', params);
          state.tabs.process.page = data.page || 1;
          state.tabs.process.totalPages = data.totalPages || 1;
          renderProcessLogs(data.logs || []);
          renderPagination('processPagination', state.tabs.process.page, state.tabs.process.totalPages, 'process');
        } catch (err) {
          console.error(err);
          toast.error('加载后处理日志失败：' + (err.message || '网络错误'));
          showEmptyState('processTable', 'processEmpty');
        }
      }

      function buildParams(page) {
        const params = {
          page: page.toString(),
          limit: pageSize.toString(),
        };
        appendDateParams(params);
        return params;
      }

      function appendDateParams(params) {
        const range = getDateParams();
        if (range.fromDate) params.fromDate = range.fromDate;
        if (range.toDate) params.toDate = range.toDate;
      }

      function getDateParams() {
        const days = 30;
        const toDate = new Date();
        const fromDate = new Date();
        fromDate.setDate(fromDate.getDate() - days);
        return {
          fromDate: fromDate.toISOString(),
          toDate: toDate.toISOString(),
        };
      }

      async function fetchJson(url, params) {
        const searchParams = new URLSearchParams();
        Object.entries(params).forEach(([key, value]) => {
          if (value !== undefined && value !== null && value !== '') {
            searchParams.append(key, value);
          }
        });
        const query = searchParams.toString();
        const res = await fetch(query ?\`\${url}?\${query}\` : url);
    if (!res.ok) {
      throw new Error('请求失败');
    }
    return res.json();
  }

  function renderUnifiedLogs(logs) {
    const table = document.getElementById('unifiedTable');
    const tbody = document.getElementById('unifiedBody');
    const empty = document.getElementById('unifiedEmpty');

    if (!tbody || !table || !empty) return;

    if (!logs.length) {
      table.style.display = 'none';
      empty.style.display = 'block';
      tbody.innerHTML = '';
      return;
    }

    table.style.display = 'table';
    empty.style.display = 'none';

    const rows = logs.map((log) => {
      const detailId = \`unified-detail-\${log.id}\`;
      return \`
        <tr class="expand-row" data-detail-id="\${detailId}">
          <td class="expand-cell"><span class="expand-icon">▶</span></td>
          <td>\${getFlowLabel(log.type)}</td>
          <td>\${escapeHtml(getUnifiedSummary(log))}</td>
          <td>\${renderStatusBadge(log.status)}</td>
          <td>\${formatDate(log.created_at)}</td>
        </tr>
        <tr class="detail-row" id="\${detailId}">
          <td colspan="5" class="detail-cell">
            <div class="detail-content">\${buildUnifiedDetail(log)}</div>
          </td>
        </tr>
      \`;
    }).join('');

    tbody.innerHTML = rows;
    bindExpandEvents('#unifiedBody');
  }

  function renderRssLogs(logs) {
    const table = document.getElementById('rssTable');
    const tbody = document.getElementById('rssBody');
    const empty = document.getElementById('rssEmpty');

    if (!tbody || !table || !empty) return;

    if (!logs.length) {
      table.style.display = 'none';
      empty.style.display = 'block';
      tbody.innerHTML = '';
      return;
    }

    table.style.display = 'table';
    empty.style.display = 'none';

    tbody.innerHTML = logs.map((log) => {
      const detailId = \`rss-detail-\${log.id}\`;
      const summary = \`\${escapeHtml(log.rss_source_name || '未命名订阅')}\`;
      const counts = \`\${log.new_articles_count ?? 0}/\${log.articles_count ?? 0}\`;
      const schedule = log.is_scheduled ? '定时' : '手动';
      return \`
        <tr class="expand-row" data-detail-id="\${detailId}">
          <td class="expand-cell"><span class="expand-icon">▶</span></td>
          <td>\${summary}<span class="chip">\${schedule}</span></td>
          <td>\${renderStatusBadge(log.status)}</td>
          <td>\${counts}</td>
          <td>\${formatDuration(log.duration_ms)}</td>
          <td>\${formatDate(log.created_at)}</td>
        </tr>
        <tr class="detail-row" id="\${detailId}">
          <td colspan="6" class="detail-cell">
            <div class="detail-content">
              <h4>执行详情</h4>
              <p>来源 ID：\${log.rss_source_id}</p>
              <p>执行方式：\${schedule}</p>
              <p>新增文章：\${log.new_articles_count ?? 0}</p>
              <p>总计文章：\${log.articles_count ?? 0}</p>
              <p>耗时：\${formatDuration(log.duration_ms)}</p>
              \${log.error_message ? \`<p>错误信息：\${escapeHtml(log.error_message)}</p>\` : ''}
            </div>
          </td>
        </tr>
      \`;
    }).join('');

    bindExpandEvents('#rssBody');
  }

  function renderCrawlLogs(logs) {
    const table = document.getElementById('crawlTable');
    const tbody = document.getElementById('crawlBody');
    const empty = document.getElementById('crawlEmpty');

    if (!tbody || !table || !empty) return;

    if (!logs.length) {
      table.style.display = 'none';
      empty.style.display = 'block';
      tbody.innerHTML = '';
      return;
    }

    table.style.display = 'table';
    empty.style.display = 'none';

    tbody.innerHTML = logs.map((log) => {
      const detailId = \`crawl-detail-\${log.id}\`;
      const period = formatYearVolumeIssue(log.crawl_year, log.crawl_volume, log.crawl_issue);
      const counts = \`\${log.new_articles_count ?? 0}/\${log.articles_count ?? 0}\`;
      return \`
        <tr class="expand-row" data-detail-id="\${detailId}">
          <td class="expand-cell"><span class="expand-icon">▶</span></td>
          <td>\${escapeHtml(log.journal_name || '-')}</td>
          <td>\${escapeHtml(period)}</td>
          <td>\${renderStatusBadge(log.status)}</td>
          <td>\${counts}</td>
          <td>\${formatDuration(log.duration_ms)}</td>
          <td>\${formatDate(log.created_at)}</td>
        </tr>
        <tr class="detail-row" id="\${detailId}">
          <td colspan="7" class="detail-cell">
            <div class="detail-content">
              <h4>执行详情</h4>
              <p>期刊 ID：\${log.journal_id}</p>
              <p>新增文章：\${log.new_articles_count ?? 0}</p>
              <p>总计文章：\${log.articles_count ?? 0}</p>
              <p>耗时：\${formatDuration(log.duration_ms)}</p>
              \${log.error_message ? \`<p>错误信息：\${escapeHtml(log.error_message)}</p>\` : '<p>错误信息：无</p>'}
            </div>
          </td>
        </tr>
      \`;
    }).join('');

    bindExpandEvents('#crawlBody');
  }

  function renderFilterLogs(logs) {
    const table = document.getElementById('filterTable');
    const tbody = document.getElementById('filterBody');
    const empty = document.getElementById('filterEmpty');

    if (!tbody || !table || !empty) return;

    if (!logs.length) {
      table.style.display = 'none';
      empty.style.display = 'block';
      tbody.innerHTML = '';
      return;
    }

    table.style.display = 'table';
    empty.style.display = 'none';

    tbody.innerHTML = logs.map((log) => {
      const detailId = \`filter-detail-\${log.id}\`;
      const domainName = getDomainName(log.domain_id);
      const statusLabel = log.is_passed ? 'passed' : 'rejected';
      return \`
        <tr class="expand-row" data-detail-id="\${detailId}">
          <td class="expand-cell"><span class="expand-icon">▶</span></td>
          <td class="article-title" title="\${escapeHtml(log.article_title || '未命名文章')}">\${escapeHtml(log.article_title || '未命名文章')}</td>
          <td class="domain-cell" title="\${escapeHtml(domainName)}">\${escapeHtml(domainName)}</td>
          <td>\${renderStatusBadge(statusLabel)}</td>
          <td>\${log.relevance_score !== null && log.relevance_score !== undefined ? log.relevance_score.toFixed(2) : '-'}</td>
          <td>\${escapeHtml(log.filter_reason || '-')}</td>
          <td>\${formatDate(log.created_at)}</td>
        </tr>
        <tr class="detail-row" id="\${detailId}">
          <td colspan="7" class="detail-cell">
            <div class="detail-content">
              <h4>过滤详情</h4>
              <p>文章 ID：\${log.article_id}</p>
              <p>领域：\${escapeHtml(domainName)}</p>
              <p>相关性分数：\${log.relevance_score !== null && log.relevance_score !== undefined ? log.relevance_score.toFixed(2) : '-'}</p>
              <p>匹配关键词：\${escapeHtml(log.matched_keywords || '-')}</p>
              <p>原因：\${escapeHtml(log.filter_reason || '-')}</p>
              \${log.llm_response ? \`<h4 style="margin-top: 12px;">LLM 响应</h4><pre>\${escapeHtml(log.llm_response)}</pre>\` : ''}
            </div>
          </td>
        </tr>
      \`;
    }).join('');

    bindExpandEvents('#filterBody');
  }

  function renderProcessLogs(logs) {
    const table = document.getElementById('processTable');
    const tbody = document.getElementById('processBody');
    const empty = document.getElementById('processEmpty');

    if (!tbody || !table || !empty) return;

    if (!logs.length) {
      table.style.display = 'none';
      empty.style.display = 'block';
      tbody.innerHTML = '';
      return;
    }

    table.style.display = 'table';
    empty.style.display = 'none';

    tbody.innerHTML = logs.map((log) => {
      const detailId = \`process-detail-\${log.id}\`;
      const stageLabel = getStageLabel(log.stage);
      const sourceLabel = log.source_origin === 'journal' ? '期刊' : 'RSS';
      return \`
        <tr class="expand-row" data-detail-id="\${detailId}">
          <td class="expand-cell"><span class="expand-icon">▶</span></td>
          <td class="article-title" title="\${escapeHtml(log.article_title || '未命名文章')}">\${escapeHtml(log.article_title || '未命名文章')}<span class="chip">\${stageLabel}</span></td>
          <td>\${renderStatusBadge(log.status)}</td>
          <td>\${formatDuration(log.duration_ms)}</td>
          <td>\${sourceLabel}</td>
          <td>\${formatDate(log.created_at)}</td>
        </tr>
        <tr class="detail-row" id="\${detailId}">
          <td colspan="6" class="detail-cell">
            <div class="detail-content">
              <h4>阶段详情</h4>
              <p>文章 ID：\${log.article_id}</p>
              <p>阶段：\${stageLabel}</p>
              <p>状态：\${getStatusText(log.status)}</p>
              <p>耗时：\${formatDuration(log.duration_ms)}</p>
              \${log.error_message ? \`<p>错误信息：\${escapeHtml(log.error_message)}</p>\` : ''}
              \${log.details ? \`<h4 style="margin-top: 12px;">附加信息</h4><pre>\${formatDetailString(log.details)}</pre>\` : ''}
            </div>
          </td>
        </tr>
      \`;
    }).join('');

    bindExpandEvents('#processBody');
  }
  function renderPagination(containerId, currentPage, totalPages, tabKey) {
    const container = document.getElementById(containerId);
    if (!container) return;

    if (!totalPages || totalPages <= 1) {
      container.style.display = 'none';
      container.innerHTML = '';
      return;
    }

    container.style.display = 'flex';
    container.innerHTML = buildPaginationHtml(currentPage, totalPages, tabKey);
  }

  function buildPaginationHtml(currentPage, totalPages, tabKey) {
    let html = '';
    if (currentPage > 1) {
      html += \`<a href="#" onclick="return changeLogPage('\${tabKey}', \${currentPage - 1});">&laquo; 上一页</a>\`;
    } else {
      html += '<span class="disabled">&laquo; 上一页</span>';
    }

    const start = Math.max(1, currentPage - 2);
    const end = Math.min(totalPages, start + 4);

    if (start > 1) {
      html += \`<a href="#" onclick="return changeLogPage('\${tabKey}', 1);">1</a>\`;
      if (start > 2) {
        html += '<span>...</span>';
      }
    }

    for (let i = start; i <= end; i++) {
      if (i === currentPage) {
        html += \`<span class="current">\${i}</span>\`;
      } else {
        html += \`<a href="#" onclick="return changeLogPage('\${tabKey}', \${i});">\${i}</a>\`;
      }
    }

    if (end < totalPages) {
      if (end < totalPages - 1) {
        html += '<span>...</span>';
      }
      html += \`<a href="#" onclick="return changeLogPage('\${tabKey}', \${totalPages});">\${totalPages}</a>\`;
    }

    if (currentPage < totalPages) {
      html += \`<a href="#" onclick="return changeLogPage('\${tabKey}', \${currentPage + 1});">下一页 &raquo;</a>\`;
    } else {
      html += '<span class="disabled">下一页 &raquo;</span>';
    }

    return html;
  }

  window.changeLogPage = function(tab, page) {
    switch (tab) {
      case 'all':
        loadUnifiedLogs(page);
        break;
      case 'rss':
        loadRssLogs(page);
        break;
      case 'crawl':
        loadCrawlLogs(page);
        break;
      case 'filter':
        loadFilterLogs(page);
        break;
      case 'process':
        loadProcessLogs(page);
        break;
    }
    return false;
  };

  function bindExpandEvents(scopeSelector) {
    const container = document.querySelector(scopeSelector);
    if (!container) return;
    container.querySelectorAll('.expand-row').forEach((row) => {
      row.addEventListener('click', () => {
        const detailId = row.getAttribute('data-detail-id');
        if (!detailId) return;
        row.classList.toggle('expanded');
        const detailRow = document.getElementById(detailId);
        if (detailRow) {
          detailRow.classList.toggle('show');
        }
      });
    });
  }

  function showEmptyState(tableId, emptyId) {
    const table = document.getElementById(tableId);
    const empty = document.getElementById(emptyId);
    if (table) table.style.display = 'none';
    if (empty) empty.style.display = 'block';
  }

  function getFlowLabel(type) {
    switch (type) {
      case 'rss_fetch':
        return 'RSS 抓取';
      case 'journal_crawl':
        return '期刊爬取';
      case 'filter':
        return '过滤';
      case 'process':
        return '后处理';
      default:
        return '流程';
    }
  }

  function getUnifiedSummary(log) {
    switch (log.type) {
      case 'rss_fetch':
        return log.data?.rss_source_name || '未命名订阅';
      case 'journal_crawl':
        return \`\${log.data?.journal_name || '-'} · \${formatYearVolumeIssue(log.data?.crawl_year, log.data?.crawl_volume, log.data?.crawl_issue)}\`;
      case 'process':
        return \`\${log.data?.article_title || '未命名文章'} · \${getStageLabel(log.data?.stage)}\`;
      case 'filter':
      default:
        return log.data?.article_title || '未命名文章';
    }
  }

  function buildUnifiedDetail(log) {
    switch (log.type) {
      case 'rss_fetch':
        return buildRssDetail(log.data);
      case 'journal_crawl':
        return buildCrawlDetail(log.data);
      case 'process':
        return buildProcessDetail(log.data);
      case 'filter':
      default:
        return buildFilterDetail(log.data);
    }
  }

  function buildFilterDetail(data) {
    const domainName = getDomainName(data?.domain_id);
    return \`
      <h4>过滤详情</h4>
      <p>文章 ID：\${data?.article_id}</p>
      <p>领域：\${escapeHtml(domainName)}</p>
      <p>相关性分数：\${data?.relevance_score !== null && data?.relevance_score !== undefined ? Number(data.relevance_score).toFixed(2) : '-'}</p>
      <p>匹配关键词：\${escapeHtml(data?.matched_keywords || '-')}</p>
      <p>原因：\${escapeHtml(data?.filter_reason || '-')}</p>
      \${data?.llm_response ? \`<h4 style="margin-top: 12px;">LLM 响应</h4><pre>\${escapeHtml(data.llm_response)}</pre>\` : ''}
    \`;
  }

  function buildRssDetail(data) {
    const schedule = data?.is_scheduled ? '定时' : '手动';
    return \`
      <h4>RSS 抓取</h4>
      <p>来源：\${escapeHtml(data?.rss_source_name || '未命名订阅')}</p>
      <p>执行方式：\${schedule}</p>
      <p>新增文章：\${data?.new_articles_count ?? 0}</p>
      <p>总计文章：\${data?.articles_count ?? 0}</p>
      <p>耗时：\${formatDuration(data?.duration_ms)}</p>
      \${data?.error_message ? \`<p>错误信息：\${escapeHtml(data.error_message)}</p>\` : ''}
    \`;
  }

  function buildCrawlDetail(data) {
    return \`
      <h4>期刊爬取</h4>
      <p>期刊：\${escapeHtml(data?.journal_name || '-')}</p>
      <p>期次：\${escapeHtml(formatYearVolumeIssue(data?.crawl_year, data?.crawl_volume, data?.crawl_issue))}</p>
      <p>新增文章：\${data?.new_articles_count ?? 0}</p>
      <p>总计文章：\${data?.articles_count ?? 0}</p>
      <p>耗时：\${formatDuration(data?.duration_ms)}</p>
      \${data?.error_message ? \`<p>错误信息：\${escapeHtml(data.error_message)}</p>\` : ''}
    \`;
  }

  function buildProcessDetail(data) {
    return \`
      <h4>后处理</h4>
      <p>文章：\${escapeHtml(data?.article_title || '未命名文章')}</p>
      <p>阶段：\${getStageLabel(data?.stage)}</p>
      <p>状态：\${getStatusText(data?.status)}</p>
      <p>耗时：\${formatDuration(data?.duration_ms)}</p>
      \${data?.error_message ? \`<p>错误信息：\${escapeHtml(data.error_message)}</p>\` : ''}
      \${data?.details ? \`<h4 style="margin-top: 12px;">附加信息</h4><pre>\${formatDetailString(data.details)}</pre>\` : ''}
    \`;
  }

  function getDomainName(domainId) {
    if (!domainId) return '-';
    const idNum = Number(domainId);
    const domain = domains.find((item) => Number(item.id) === idNum);
    return domain ? domain.name : '-';
  }

  function renderStatusBadge(status) {
    const normalized = (status || '').toString().toLowerCase();
    let cls = '';
    let text = status || '-';
    switch (normalized) {
      case 'passed':
      case 'success':
      case 'completed':
        cls = 'passed';
        text = normalized === 'passed' ? '通过' : '成功';
        if (normalized === 'completed') text = '完成';
        break;
      case 'partial':
        cls = 'partial';
        text = '部分成功';
        break;
      case 'processing':
        cls = 'processing';
        text = '处理中';
        break;
      case 'skipped':
        cls = 'skipped';
        text = '跳过';
        break;
      case 'failed':
      case 'rejected':
        cls = 'failed';
        text = normalized === 'rejected' ? '拒绝' : '失败';
        break;
      default:
        cls = '';
    }
    return \`<span class="status-badge \${cls}">\${text}</span>\`;
  }

  function getStatusText(status) {
    const normalized = (status || '').toString().toLowerCase();
    switch (normalized) {
      case 'passed':
        return '通过';
      case 'rejected':
        return '拒绝';
      case 'success':
        return '成功';
      case 'failed':
        return '失败';
      case 'partial':
        return '部分成功';
      case 'processing':
        return '处理中';
      case 'completed':
        return '完成';
      case 'skipped':
        return '跳过';
      default:
        return status || '-';
    }
  }

  function getStageLabel(stage) {
    switch (stage) {
      case 'markdown':
        return '内容清洗';
      case 'translate':
        return '翻译';
      case 'vector':
        return '向量化';
      case 'related':
        return '相关文章';
      case 'pipeline_complete':
        return '流程完成';
      default:
        return '阶段';
    }
  }

  function formatDetailString(value) {
    try {
      const parsed = JSON.parse(value);
      return escapeHtml(JSON.stringify(parsed, null, 2));
    } catch (err) {
      return escapeHtml(value);
    }
  }

  function escapeHtml(str) {
    if (str === null || str === undefined) return '';
    const div = document.createElement('div');
    div.textContent = String(str);
    return div.innerHTML;
  }

  function formatDate(value) {
    if (!value) return '-';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '-';
    // 手动格式化以确保正确的时区转换
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const hour = String(date.getHours()).padStart(2, '0');
    const minute = String(date.getMinutes()).padStart(2, '0');
    return \`\${year}/\${month}/\${day} \${hour}:\${minute}\`;
  }

  function formatDuration(ms) {
    if (ms === null || ms === undefined) return '-';
    if (ms < 1000) return \`\${ms}ms\`;
    return \`\${(ms / 1000).toFixed(1)}s\`;
  }

  function formatYearVolumeIssue(year, volume, issue) {
    if (!year) return '-';
    const vol = volume ? \`Vol.\${volume}\` : '';
    const iss = issue ? \`Issue.\${issue}\` : '';
    return [year, vol, iss].filter(Boolean).join(' ');
  }
})();
