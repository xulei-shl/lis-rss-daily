<!-- 企业微信设置 Section -->
<section class="settings-panel" data-tab="wechat">
  <div class="wechat-section">
    <div class="section-header">
      <h2>企业微信通知</h2>
      <p class="section-description">
        配置企业微信群机器人接收每日总结推送。
        <a href="https://developer.work.weixin.qq.com/document/path/91770" target="_blank" rel="noopener">
          如何创建群机器人？
        </a>
      </p>
    </div>

    <!-- Webhooks List -->
    <div class="wechat-webhooks-section">
      <div class="webhooks-header">
        <h3>Webhook 列表</h3>
        <button type="button" id="addWeChatWebhookBtn" class="btn btn-secondary btn-small">
          + 添加 Webhook
        </button>
      </div>

      <div id="wechatWebhooksList" class="wechat-webhooks-list">
        <!-- Webhooks will be rendered here -->
      </div>

      <div id="wechatWebhooksEmpty" class="wechat-webhooks-empty" style="display: none;">
        <p>暂无 Webhook 配置。点击上方按钮添加。</p>
      </div>
    </div>

    <div id="wechatStatus" class="wechat-status"></div>
  </div>
</section>

<!-- 添加/编辑企业微信 Webhook 模态框 -->
<div class="modal-overlay" id="wechatWebhookModal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="wechatWebhookModalTitle">添加 Webhook</h3>
      <button type="button" class="modal-close" onclick="closeWeChatWebhookModal()">&times;</button>
    </div>
    <form id="wechatWebhookForm">
      <input type="hidden" id="wechatWebhookId" name="id">
      <div class="form-group">
        <label for="wechatWebhookName">名称</label>
        <input
          type="text"
          id="wechatWebhookName"
          name="name"
          placeholder="例如：工作群"
          autocomplete="off"
          required
        >
        <small class="form-hint">
          用于在设置页面识别此 Webhook
        </small>
      </div>

      <div class="form-group">
        <label for="wechatWebhookUrl">Webhook URL</label>
        <input
          type="text"
          id="wechatWebhookUrl"
          name="url"
          placeholder="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx"
          autocomplete="off"
          required
        >
        <small class="form-hint">
          企业微信群机器人 Webhook 地址
        </small>
      </div>

      <div class="form-group">
        <label>推送类型</label>
        <div class="checkbox-group">
          <label>
            <input type="checkbox" id="wechatWebhookDailySummary" name="daily_summary" checked>
            接收每日总结（通过的期刊/资讯）
          </label>
          <label>
            <input type="checkbox" id="wechatWebhookJournalAll" name="journal_all" checked>
            接收全部期刊总结（包含未通过的）
          </label>
          <label>
            <input type="checkbox" id="wechatWebhookNewArticles" name="new_articles" checked>
            接收新增文章
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" id="wechatWebhookEnabled" name="enabled" checked>
          启用
        </label>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeWeChatWebhookModal()">取消</button>
        <button type="submit" class="btn btn-primary">保存</button>
      </div>
    </form>
  </div>
</div>

