  border: 1px solid rgba(26, 77, 122, 0.2);
}

/* Tags */
.telegram-chat-tags {
  display: flex;
  gap: 4px;
}

.telegram-chat-tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-family: var(--font-meta);
  font-size: 0.65rem;
  font-weight: 500;
  background: var(--bg-subtle);
  color: var(--text-secondary);
  border: 1px solid var(--border);
