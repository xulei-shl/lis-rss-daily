}

.telegram-chats-empty {
  text-align: center;
  padding: 30px;
  color: var(--text-secondary, #666);
  background: var(--bg-secondary, #f5f5f5);
  border-radius: 8px;
  border: 1px dashed var(--border-color, #e0e0e0);
