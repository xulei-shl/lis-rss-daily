<!-- Telegram Settings Section -->
<section class="settings-panel" data-tab="telegram">
  <div class="telegram-section">
    <div class="section-header">
      <h2>Telegram 通知</h2>
      <p class="section-description">
        配置 Telegram Bot 接收每日总结推送。
        <a href="https://core.telegram.org/bots#how-do-i-create-a-bot" target="_blank" rel="noopener">
          如何创建 Bot？
        </a>
      </p>
    </div>

    <form id="telegramForm" class="telegram-form">
      <div class="form-group">
        <label for="telegramEnabled">
          <input type="checkbox" id="telegramEnabled" name="enabled">
          启用 Telegram 通知
        </label>
      </div>

      <div id="telegramConfigFields" class="telegram-config-fields">
        <div class="form-group">
          <label for="telegramBotToken">Bot Token</label>
          <div class="input-with-action">
            <input
              type="password"
              id="telegramBotToken"
              name="botToken"
              placeholder="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"
              autocomplete="off"
            >
            <button type="button" id="telegramSaveTokenBtn" class="btn btn-secondary btn-small">
              保存
            </button>
          </div>
          <small class="form-hint">
            从 @BotFather 获取。格式：数字:字符串
          </small>
        </div>

        <!-- Telegram Chats List -->
        <div class="telegram-chats-section">
          <div class="chats-header">
            <h3>接收者列表</h3>
            <button type="button" id="addTelegramChatBtn" class="btn btn-secondary btn-small">
              + 添加接收者
            </button>
          </div>

          <div id="telegramChatsList" class="telegram-chats-list">
            <!-- Chats will be rendered here -->
          </div>

          <div id="telegramChatsEmpty" class="telegram-chats-empty" style="display: none;">
            <p>暂无接收者配置。点击上方按钮添加。</p>
          </div>
        </div>
      </div>
    </form>

    <div id="telegramStatus" class="telegram-status"></div>
  </div>
</section>

<!-- Add/Edit Telegram Chat Modal -->
<div class="modal-overlay" id="telegramChatModal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="telegramChatModalTitle">添加接收者</h3>
      <button type="button" class="modal-close" onclick="closeTelegramChatModal()">&times;</button>
    </div>
    <form id="telegramChatForm">
      <input type="hidden" id="telegramChatId" name="id">
      <div class="form-group">
        <label for="telegramChatChatId">Chat ID</label>
        <input
          type="text"
          id="telegramChatChatId"
          name="chatId"
          placeholder="123456789 或 @channelname"
          autocomplete="off"
          required
        >
        <small class="form-hint">
          从 @userinfobot 获取。可以是数字或 @开头的用户名
        </small>
      </div>

      <div class="form-group">
        <label for="telegramChatName">显示名称（可选）</label>
        <input
          type="text"
          id="telegramChatName"
          name="chatName"
          placeholder="例如：我的手机"
          autocomplete="off"
        >
        <small class="form-hint">
          用于在设置页面识别接收者
        </small>
      </div>

      <div class="form-group">
        <label for="telegramChatRole">权限角色</label>
        <select id="telegramChatRole" name="role">
          <option value="viewer">观察者 - 只接收推送</option>
          <option value="admin">管理员 - 可交互（标记已读、评分）</option>
        </select>
        <small class="form-hint">
          观察者只能接收推送，管理员可以在 Telegram 中标记文章已读和评分
        </small>
      </div>

      <div class="form-group">
        <label>推送类型</label>
        <div class="checkbox-group">
          <label>
            <input type="checkbox" id="telegramChatDailySummary" name="dailySummary" checked>
            接收每日总结（通过的期刊/资讯）
          </label>
          <label>
            <input type="checkbox" id="telegramChatJournalAll" name="journalAll" checked>
            接收全部期刊总结（包含未通过的）
          </label>
          <label>
            <input type="checkbox" id="telegramChatNewArticles" name="newArticles" checked>
            接收新增文章
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" id="telegramChatIsActive" name="isActive" checked>
          启用
        </label>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeTelegramChatModal()">取消</button>
        <button type="submit" class="btn btn-primary">保存</button>
      </div>
    </form>
  </div>
</div>

<style>
