  padding: 6px 12px;
  font-size: 0.85rem;
}

.telegram-chats-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.telegram-chat-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 15px;
  background: var(--bg-secondary, #f5f5f5);
  border-radius: 8px;
  border: 1px solid var(--border-color, #e0e0e0);
}

.telegram-chat-item.inactive {
  opacity: 0.6;
}

.telegram-chat-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.telegram-chat-name {
  font-weight: 500;
}

.telegram-chat-details {
  display: flex;
  gap: 10px;
  font-size: 0.85rem;
  color: var(--text-secondary, #666);
}

.telegram-chat-role {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 4px;
