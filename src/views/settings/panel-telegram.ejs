  background: var(--bg-subtle);
}

.telegram-chat-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  flex: 1;
}

.telegram-chat-name {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--text-primary);
  font-family: var(--font-meta);
}

.telegram-chat-details {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}

/* Role Badge */
.telegram-chat-role {
