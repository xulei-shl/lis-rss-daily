<%- include('layout', { pageTitle: pageTitle, pageStyles: '<link rel="stylesheet" href="/css/pages/deepsearch.css">', user: user, guestSummaryEnabled: false, body: `
  <div class="page-header">
    <h1 class="page-title">深度检索</h1>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="filters-bar deepsearch-filters">
        <div class="filter-row deepsearch-filter-row">
        <div class="filter-group deepsearch-keyword-group">
          <label class="filter-label" for="keywordInput">任务名关键词</label>
          <input type="search" id="keywordInput" class="filter-select" placeholder="输入任务名称关键词">
        </div>
        <div class="filter-group deepsearch-status-group">
          <label class="filter-label" for="statusFilter">状态</label>
          <select id="statusFilter" class="filter-select">
            <option value="">全部状态</option>
            <option value="pending">等待中</option>
            <option value="running">运行中</option>
            <option value="completed">已完成</option>
            <option value="failed">失败</option>
          </select>
        </div>
        <div class="filter-group deepsearch-date-group">
          <label class="filter-label" for="createdFrom">任务时间</label>
          <div class="date-range-group">
            <input type="date" id="createdFrom" class="filter-date">
            <span class="date-separator">至</span>
            <input type="date" id="createdTo" class="filter-date">
          </div>
        </div>
      </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
      <h2 class="card-title">任务列表</h2>
      <button type="button" class="btn btn-primary btn-sm" id="openCreateModalBtn">创建任务</button>
    </div>
      <div class="loading" id="tasksLoading" style="display:none;">加载中</div>
      <div class="empty-state" id="tasksEmpty" style="display:none;">
        <div class="empty-state-title">暂无任务</div>
        <div class="empty-state-desc">请先创建任务或调整检索条件</div>
      </div>
      <div class="table-container" id="tasksTableContainer" style="display:none;">
        <table>
          <thead>
            <tr>
              <th>任务名称</th>
              <th>状态</th>
              <th>进度</th>
              <th>创建时间</th>
              <th>完成时间</th>
              <th>文章数</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody id="tasksTableBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="createTaskModal">
    <div class="modal modal-large">
      <div class="modal-header">
        <h3>创建深度检索任务</h3>
        <button class="modal-close" type="button" id="closeCreateModalBtn">&times;</button>
      </div>
      <div class="modal-body">
        <form id="createTaskForm">
          <div class="form-group">
            <label for="taskName">任务名称</label>
            <input type="text" id="taskName" name="task_name" placeholder="请输入任务名称" required>
          </div>

          <div class="form-group">
            <label for="seedTitle">种子文献 <a class="link-text" href="/templates/deepsearch-input.md" target="_blank" rel="noopener">参数说明</a></label>
            <div style="display:flex; gap:12px; align-items:flex-end;">
              <div style="flex:1;">
                <label for="seedTitle" style="display:block; margin-bottom:6px;">题名</label>
                <input type="text" id="seedTitle" name="seed_title" placeholder="输入题名，支持粘贴 - 标题@ID 自动识别" required>
              </div>
              <div style="width:180px;">
                <label for="seedArticleId" style="display:block; margin-bottom:6px;">ID（可空）</label>
                <input type="number" id="seedArticleId" name="seed_article_id" min="1" step="1" placeholder="可选">
              </div>
            </div>
          </div>

          <div class="create-form-grid">
            <div class="form-group">
              <label for="rounds">迭代轮次</label>
              <input type="number" id="rounds" name="rounds" value="1" min="1" max="3" step="1" placeholder="输入数值">
              <div id="roundsError" style="display:none; color:#d93025; font-size:12px; margin-top:6px;"></div>
            </div>
            <div class="form-group">
              <label for="semanticLimit">相关文献数量</label>
              <input type="number" id="semanticLimit" name="semantic_limit" value="5" min="1" max="10" step="1" placeholder="输入数值">
              <div id="semanticLimitError" style="display:none; color:#d93025; font-size:12px; margin-top:6px;"></div>
            </div>
            <div class="form-group">
              <label for="maxFinalArticles">最大保留文章数</label>
              <input type="number" id="maxFinalArticles" name="max_final_articles" value="15" min="1" max="30" step="1" placeholder="输入数值">
              <div id="maxFinalArticlesError" style="display:none; color:#d93025; font-size:12px; margin-top:6px;"></div>
            </div>
            <div class="form-group">
              <label for="scoreThreshold">相关性阈值</label>
              <input type="number" id="scoreThreshold" name="score_threshold" value="0.75" min="0.60" max="1.00" step="0.01" placeholder="输入数值">
              <div id="scoreThresholdError" style="display:none; color:#d93025; font-size:12px; margin-top:6px;"></div>
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" id="cancelCreateBtn">取消</button>
        <button type="button" class="btn btn-primary" id="submitCreateBtn">创建并开始检索</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="taskDetailModal">
    <div class="modal modal-large">
      <div class="modal-header">
        <h3>任务详情</h3>
        <button class="modal-close" type="button" id="closeDetailModalBtn">&times;</button>
      </div>
      <div class="modal-body" id="taskDetailContent"></div>
    </div>
  </div>

  <script>
    let tasks = [];
    let listRefreshTimer = null;
    let detailRefreshTimer = null;
    let currentDetailTaskId = null;
    let searchDebounceTimer = null;
    let detailLogScrollTop = 0;
    let detailLogPinnedBottom = true;

    document.addEventListener('DOMContentLoaded', () => {
      bindEvents();
      loadTasks();
      startListAutoRefresh();
    });

    function bindEvents() {
      document.getElementById('openCreateModalBtn').addEventListener('click', openCreateModal);
      document.getElementById('closeCreateModalBtn').addEventListener('click', closeCreateModal);
      document.getElementById('cancelCreateBtn').addEventListener('click', closeCreateModal);
      document.getElementById('submitCreateBtn').addEventListener('click', submitCreateTask);
      document.getElementById('closeDetailModalBtn').addEventListener('click', closeTaskDetail);
      const seedTitleInput = document.getElementById('seedTitle');
      seedTitleInput.addEventListener('paste', () => {
        setTimeout(() => {
          tryParseSeedTitleIntoFields();
        }, 0);
      });
      seedTitleInput.addEventListener('blur', tryParseSeedTitleIntoFields);
      bindNumericFieldValidation();

      document.getElementById('keywordInput').addEventListener('input', () => {
        scheduleAutoSearch();
      });
      document.getElementById('statusFilter').addEventListener('change', () => {
        loadTasks();
      });
      document.getElementById('createdFrom').addEventListener('change', () => {
        loadTasks();
      });
      document.getElementById('createdTo').addEventListener('change', () => {
        loadTasks();
      });

      document.getElementById('keywordInput').addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          loadTasks();
        }
      });

      window.addEventListener('click', (event) => {
        const createModal = document.getElementById('createTaskModal');
        const detailModal = document.getElementById('taskDetailModal');
        if (event.target === createModal) closeCreateModal();
        if (event.target === detailModal) closeTaskDetail();
      });
    }

    function scheduleAutoSearch() {
      if (searchDebounceTimer) {
        clearTimeout(searchDebounceTimer);
      }
      searchDebounceTimer = setTimeout(() => {
        loadTasks();
      }, 300);
    }

    function startListAutoRefresh() {
      stopListAutoRefresh();
      listRefreshTimer = setInterval(() => {
        if (tasks.some(task => task.status === 'running' || task.status === 'pending')) {
          loadTasks(false);
        }
      }, 5000);
    }

    function stopListAutoRefresh() {
      if (listRefreshTimer) {
        clearInterval(listRefreshTimer);
        listRefreshTimer = null;
      }
    }

    function buildQueryString() {
      const params = new URLSearchParams();
      const keyword = document.getElementById('keywordInput').value.trim();
      const status = document.getElementById('statusFilter').value;
      const createdFrom = document.getElementById('createdFrom').value;
      const createdTo = document.getElementById('createdTo').value;

      if (keyword) params.set('keyword', keyword);
      if (status) params.set('status', status);
      if (createdFrom) params.set('created_from', createdFrom);
      if (createdTo) params.set('created_to', createdTo);

      const query = params.toString();
      return query ? '?' + query : '';
    }

    async function loadTasks(showLoading = true) {
      const loadingEl = document.getElementById('tasksLoading');
      const emptyEl = document.getElementById('tasksEmpty');
      const tableEl = document.getElementById('tasksTableContainer');

      if (showLoading) {
        loadingEl.style.display = 'block';
      }
      emptyEl.style.display = 'none';
      tableEl.style.display = 'none';

      try {
        const response = await fetch('/api/deepsearch/tasks' + buildQueryString(), { credentials: 'same-origin' });
        if (response.status === 401) {
          window.location.href = '/login';
          return;
        }
        if (!response.ok) {
          throw new Error('加载任务失败');
        }

        const data = await response.json();
        tasks = Array.isArray(data.tasks) ? data.tasks : [];
        renderTasks();
      } catch (error) {
        console.error('load tasks error', error);
        tasks = [];
        renderTasks();
        showToast('任务列表加载失败', 'error');
      } finally {
        loadingEl.style.display = 'none';
      }
    }

    function renderTasks() {
      const emptyEl = document.getElementById('tasksEmpty');
      const tableEl = document.getElementById('tasksTableContainer');
      const tbody = document.getElementById('tasksTableBody');

      if (tasks.length === 0) {
        emptyEl.style.display = 'block';
        tableEl.style.display = 'none';
        tbody.innerHTML = '';
        return;
      }

      emptyEl.style.display = 'none';
      tableEl.style.display = 'block';

      tbody.innerHTML = tasks.map((task) => {
        const canDownload = task.status === 'completed';
        const progressText = task.status === 'completed'
          ? '100%'
          : (task.status === 'failed' ? '-' : '执行中');

        return \`
          <tr>
            <td>\${escapeHtml(task.taskName || '')}</td>
            <td>\${renderStatusBadge(task.status)}</td>
            <td>\${progressText}</td>
            <td>\${formatDateTime(task.createdAt)}</td>
            <td>\${formatDateTime(task.completedAt)}</td>
            <td>\${Number(task.articleCount || 0)}</td>
            <td class="table-actions-cell">
              <button type="button" class="btn btn-secondary task-action-btn" onclick="viewTaskDetail(\${task.id})">查看</button>
              <button type="button" class="btn btn-secondary task-action-btn" onclick="downloadTask(\${task.id})" \${canDownload ? '' : 'disabled'}>下载</button>
              <button type="button" class="btn btn-danger task-action-btn" onclick="deleteTask(\${task.id})">删除</button>
            </td>
          </tr>
        \`;
      }).join('');
    }

    function renderStatusBadge(status) {
      const textMap = {
        pending: '等待中',
        running: '运行中',
        completed: '已完成',
        failed: '失败',
      };
      const cls = status === 'running' ? 'processing' : (status || '');
      return \`<span class="status-badge \${cls}">\${textMap[status] || escapeHtml(status || '-')}</span>\`;
    }

    function openCreateModal() {
      document.getElementById('createTaskModal').classList.add('active');
    }

    function closeCreateModal() {
      document.getElementById('createTaskModal').classList.remove('active');
    }

    function setFieldError(inputId, message) {
      const inputEl = document.getElementById(inputId);
      const errorEl = document.getElementById(inputId + 'Error');
      if (!inputEl || !errorEl) return;

      if (message) {
        inputEl.style.borderColor = '#d93025';
        errorEl.textContent = message;
        errorEl.style.display = 'block';
      } else {
        inputEl.style.borderColor = '';
        errorEl.textContent = '';
        errorEl.style.display = 'none';
      }
    }

    function formatNumberValue(value, isInteger) {
      if (isInteger) {
        return String(Math.trunc(value));
      }
      return value.toFixed(2);
    }

    function validateNumberField(field) {
      const inputEl = document.getElementById(field.id);
      if (!inputEl) return null;

      const raw = String(inputEl.value || '').trim();
      if (!raw) {
        setFieldError(field.id, field.label + '不能为空');
        return null;
      }

      let parsed = Number(raw);
      if (!Number.isFinite(parsed)) {
        setFieldError(field.id, field.label + '请输入有效数字');
        return null;
      }

      if (!field.integer) {
        const parts = raw.split('.');
        const decimalLength = parts.length > 1 ? parts[1].length : 0;
        if (decimalLength > 2) {
          setFieldError(field.id, field.label + '最多保留2位小数');
          return null;
        }
      } else if (!Number.isInteger(parsed)) {
        setFieldError(field.id, field.label + '必须是整数');
        return null;
      }

      if (field.clampOnBlur) {
        parsed = Math.min(field.max, Math.max(field.min, parsed));
        if (field.integer) {
          parsed = Math.round(parsed);
        } else {
          parsed = Math.round(parsed * 100) / 100;
        }
        inputEl.value = formatNumberValue(parsed, field.integer);
      }

      if (parsed < field.min || parsed > field.max) {
        setFieldError(field.id, field.label + '必须在 ' + field.min + ' - ' + field.max + ' 之间');
        return null;
      }

      setFieldError(field.id, '');
      return parsed;
    }

    function getNumericFieldConfigs(clampOnBlur) {
      return [
        { id: 'rounds', label: '迭代轮次', min: 1, max: 3, integer: true, clampOnBlur },
        { id: 'semanticLimit', label: '相关文献数量', min: 1, max: 10, integer: true, clampOnBlur },
        { id: 'maxFinalArticles', label: '最大保留文章数', min: 1, max: 30, integer: true, clampOnBlur },
        { id: 'scoreThreshold', label: '相关性阈值', min: 0.60, max: 1.00, integer: false, clampOnBlur },
      ];
    }

    function bindNumericFieldValidation() {
      const fields = getNumericFieldConfigs(false);
      fields.forEach((field) => {
        const inputEl = document.getElementById(field.id);
        if (!inputEl) return;
        inputEl.addEventListener('input', () => {
          validateNumberField(field);
        });
        inputEl.addEventListener('blur', () => {
          validateNumberField({ ...field, clampOnBlur: true });
        });
      });
    }

    function parseSeedTextToTitleAndId(seedText) {
      const singleLine = String(seedText || '').replace(/\\r?\\n+/g, ' ').trim();
      if (!singleLine) {
        return { title: '', articleId: '' };
      }

      const withoutBullet = singleLine.replace(/^\\-\\s*/, '').trim();
      const withAtIdMatch = withoutBullet.match(/^(.+?)\\s*@\\s*(\\d+)\\s*$/);
      if (withAtIdMatch) {
        return { title: withAtIdMatch[1].trim(), articleId: withAtIdMatch[2] };
      }

      const withColonIdMatch = withoutBullet.match(/^(.+?)\\s*[：:]\\s*(\\d+)\\s*$/);
      if (withColonIdMatch) {
        return { title: withColonIdMatch[1].trim(), articleId: withColonIdMatch[2] };
      }

      return { title: withoutBullet, articleId: '' };
    }

    function tryParseSeedTitleIntoFields() {
      const seedTitleInput = document.getElementById('seedTitle');
      const seedArticleIdInput = document.getElementById('seedArticleId');
      const raw = seedTitleInput.value.trim();
      const looksLikeSeedLine = /^\\-\\s+/.test(raw) || /[@：:]\\s*\\d+\\s*$/.test(raw);
      if (!looksLikeSeedLine) {
        return;
      }

      const parsed = parseSeedTextToTitleAndId(raw);
      if (!parsed.title) {
        return;
      }

      seedTitleInput.value = parsed.title;
      if (parsed.articleId) {
        seedArticleIdInput.value = parsed.articleId;
      }
    }

    async function submitCreateTask() {
      const taskName = document.getElementById('taskName').value.trim();
      const seedTitleRaw = document.getElementById('seedTitle').value;
      const seedArticleIdRaw = document.getElementById('seedArticleId').value.trim();
      const parsedSeed = parseSeedTextToTitleAndId(seedTitleRaw);
      const seedTitle = parsedSeed.title;
      const seedArticleId = seedArticleIdRaw || parsedSeed.articleId;
      const submitValidateFields = getNumericFieldConfigs(true);
      const rounds = validateNumberField(submitValidateFields[0]);
      const semanticLimit = validateNumberField(submitValidateFields[1]);
      const maxFinalArticles = validateNumberField(submitValidateFields[2]);
      const scoreThreshold = validateNumberField(submitValidateFields[3]);

      if (!taskName || !seedTitle) {
        showToast('请填写任务名称和种子文献题名', 'error');
        return;
      }
      if (seedArticleId && !/^\\d+$/.test(seedArticleId)) {
        showToast('种子文献ID必须是正整数', 'error');
        return;
      }
      if (rounds === null || semanticLimit === null || maxFinalArticles === null || scoreThreshold === null) {
        showToast('请修正参数范围后再提交', 'error');
        return;
      }
      const inputMd = seedArticleId ? '- ' + seedTitle + '@' + seedArticleId : '- ' + seedTitle;

      const submitBtn = document.getElementById('submitCreateBtn');
      submitBtn.disabled = true;

      try {
        const response = await fetch('/api/deepsearch/tasks', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            task_name: taskName,
            input_md: inputMd,
            rounds,
            semantic_limit: semanticLimit,
            max_final_articles: maxFinalArticles,
            score_threshold: scoreThreshold,
          }),
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.error || '创建任务失败');
        }

        document.getElementById('createTaskForm').reset();
        closeCreateModal();
        await loadTasks();
        showToast('任务创建成功', 'success');
      } catch (error) {
        console.error('create task error', error);
        showToast(error instanceof Error ? error.message : '创建任务失败', 'error');
      } finally {
        submitBtn.disabled = false;
      }
    }

    async function viewTaskDetail(taskId) {
      currentDetailTaskId = taskId;
      document.getElementById('taskDetailModal').classList.add('active');
      await refreshTaskDetail();
      startDetailAutoRefresh();
    }

    function closeTaskDetail() {
      currentDetailTaskId = null;
      stopDetailAutoRefresh();
      document.getElementById('taskDetailModal').classList.remove('active');
    }

    function startDetailAutoRefresh() {
      stopDetailAutoRefresh();
      detailRefreshTimer = setInterval(() => {
        if (currentDetailTaskId) {
          refreshTaskDetail();
        }
      }, 4000);
    }

    function stopDetailAutoRefresh() {
      if (detailRefreshTimer) {
        clearInterval(detailRefreshTimer);
        detailRefreshTimer = null;
      }
    }

    async function refreshTaskDetail() {
      if (!currentDetailTaskId) return;

      const content = document.getElementById('taskDetailContent');
      content.innerHTML = '<div class="loading">加载任务详情</div>';

      try {
        const response = await fetch('/api/deepsearch/tasks/' + currentDetailTaskId, { credentials: 'same-origin' });
        if (!response.ok) {
          throw new Error('获取任务详情失败');
        }
        const task = await response.json();
        renderTaskDetail(task);
        await loadTasks(false);

        if (task.status === 'completed' || task.status === 'failed') {
          stopDetailAutoRefresh();
        }
      } catch (error) {
        console.error('detail error', error);
        content.innerHTML = '<div class="empty-state"><div class="empty-state-title">加载失败</div><div class="empty-state-desc">请稍后重试</div></div>';
      }
    }

    function renderTaskDetail(task) {
      const content = document.getElementById('taskDetailContent');
      const progress = task.progress || {};
      const result = task.result || {};
      const searchStats = result.searchStats || null;
      const logs = Array.isArray(task.logs) && task.logs.length > 0
        ? task.logs
        : buildFallbackLogs(task, progress);
      const failedItems = extractFailedItemsFromLogs(logs);
      const previousLogEl = document.getElementById('taskLogLines');
      if (previousLogEl) {
        detailLogScrollTop = previousLogEl.scrollTop;
        const distanceToBottom = previousLogEl.scrollHeight - previousLogEl.scrollTop - previousLogEl.clientHeight;
        detailLogPinnedBottom = distanceToBottom <= 24;
      }

      const progressText = task.status === 'completed'
        ? '100%'
        : (task.status === 'failed' ? '-' : ((progress.current || 0) + '/' + (progress.total || 100)));
      const progressLabel = (progress.step || '未知') + ' (' + progressText + ')';

      content.innerHTML = \`
        <div class="detail-grid">
          <div class="detail-row"><span>任务名称</span><strong>\${escapeHtml(task.taskName || '-')}</strong></div>
          <div class="detail-row"><span>创建时间→完成时间</span><strong>\${formatDateTime(task.createdAt)} → \${formatDateTime(task.completedAt)}</strong></div>
          <div class="detail-row detail-row-full detail-row-progress"><span>进度/状态</span><strong class="detail-inline-badges">\${renderProgressBadge(progressLabel)} <span class="detail-inline-sep">|</span> \${renderStatusBadge(task.status)}</strong></div>
          <div class="detail-row detail-row-full detail-row-step1"><span>检索统计（步骤一）</span><strong>\${formatSearchStats(searchStats)}</strong></div>
          <div class="detail-row detail-row-full detail-row-step2"><span>产出统计（步骤二）</span><strong>文章 \${Number(result.articleCount || 0)} / PDF 成功 \${Number(result.pdfSummarySuccess || 0)} / PDF 失败 \${Number(result.pdfSummaryFailed || 0)}</strong></div>
          <div class="detail-row detail-row-full detail-row-failed"><span>失败文章（题名+ID）</span><strong>\${formatFailedItems(failedItems)}</strong></div>
        </div>
        <div class="log-block">
          <h4>执行日志 <span class="log-count">共 \${logs.length} 条</span></h4>
          <div class="log-lines" id="taskLogLines">\${renderLogsHtml(logs)}</div>
        </div>
      \`;

      const currentLogEl = document.getElementById('taskLogLines');
      if (currentLogEl) {
        if (detailLogPinnedBottom) {
          currentLogEl.scrollTop = currentLogEl.scrollHeight;
        } else {
          currentLogEl.scrollTop = detailLogScrollTop;
        }
        currentLogEl.addEventListener('scroll', () => {
          detailLogScrollTop = currentLogEl.scrollTop;
          const distanceToBottom = currentLogEl.scrollHeight - currentLogEl.scrollTop - currentLogEl.clientHeight;
          detailLogPinnedBottom = distanceToBottom <= 24;
        });
      }
    }

    function renderLogsHtml(logs) {
      if (!Array.isArray(logs) || logs.length === 0) {
        return '<div class="log-line log-line-info">暂无日志</div>';
      }

      return logs.map((line) => {
        const cls = getLogLineClass(line);
        return '<div class="log-line ' + cls + '">' + escapeHtml(line) + '</div>';
      }).join('');
    }

    function getLogLineClass(line) {
      const text = String(line || '');
      if (text.includes('题名：') && text.includes('；ID：')) {
        return 'log-line-failed-item';
      }
      if (
        text.includes('ID检索第') ||
        text.includes('语义检索词数量') ||
        text.includes('过滤后') ||
        text.includes('新增') ||
        text.includes('步骤一统计')
      ) {
        return 'log-line-metric';
      }
      if (text.includes('失败') || text.includes('异常') || text.includes('Error')) {
        return 'log-line-error';
      }
      if (text.includes('成功') || text.includes('完成')) {
        return 'log-line-success';
      }
      if (text.includes('步骤') || text.includes('迭代') || text.includes('当前步骤')) {
        return 'log-line-step';
      }
      return 'log-line-info';
    }

    function renderProgressBadge(text) {
      return '<span class="status-badge progress-badge">' + escapeHtml(text || '-') + '</span>';
    }

    function formatSearchStats(stats) {
      if (!stats) {
        return '-';
      }

      const seed = Number(stats.seedArticleCount || 0);
      const related = Number(stats.relatedArticlesCount || 0);
      const relatedFiltered = Number(stats.relatedArticlesFilteredCount || 0);
      const relatedAdded = Number(stats.relatedArticlesUniqueAddedCount || 0);
      const semanticTerms = Number(stats.semanticSearchTermsCount || 0);
      const semanticHits = Number(stats.semanticSearchHitsCount || 0);
      const semanticFiltered = Number(stats.semanticSearchFilteredCount || 0);
      const semanticAdded = Number(stats.semanticSearchUniqueAddedCount || 0);
      const configuredRounds = Number(stats.iterationRoundsConfigured || 0);
      const executedRounds = Number(stats.iterationRoundsExecuted || 0);

      return [
        '种子 ' + seed,
        '相关文章(原始/过滤/新增) ' + related + '/' + relatedFiltered + '/' + relatedAdded,
        '语义(检索词/原始/过滤/新增) ' + semanticTerms + '/' + semanticHits + '/' + semanticFiltered + '/' + semanticAdded,
        '轮次(配置→实际) ' + configuredRounds + '→' + executedRounds,
      ].join(' / ');
    }

    function extractFailedItemsFromLogs(logs) {
      if (!Array.isArray(logs) || logs.length === 0) {
        return [];
      }

      const seen = new Set();
      const items = [];

      for (const line of logs) {
        const text = String(line || '');
        const titleStart = text.indexOf('题名：');
        const idStart = text.indexOf('；ID：');
        if (titleStart < 0 || idStart < 0 || idStart <= titleStart) {
          continue;
        }

        const title = text.slice(titleStart + 3, idStart).trim();
        const articleId = text.slice(idStart + 4).trim();
        if (!title) {
          continue;
        }

        const key = title + '||' + articleId;
        if (seen.has(key)) {
          continue;
        }
        seen.add(key);
        items.push({ title, articleId: articleId || 'N/A' });
      }

      return items;
    }

    function formatFailedItems(items) {
      if (!Array.isArray(items) || items.length === 0) {
        return '-';
      }

      return items.map((item, index) => {
        return (index + 1) + '. ' + escapeHtml(item.title) + '（ID: ' + escapeHtml(item.articleId) + '）';
      }).join('<br>');
    }

    function buildFallbackLogs(task, progress) {
      const logs = [];
      logs.push('[' + formatDateTime(task.createdAt) + '] 任务已创建');

      if (task.status === 'running' || task.status === 'pending') {
        logs.push('[' + formatDateTime(new Date().toISOString()) + '] 当前步骤: ' + (progress.step || '执行中'));
      }

      if (task.status === 'completed') {
        logs.push('[' + formatDateTime(task.completedAt) + '] 任务执行完成');
      }

      if (task.status === 'failed' && task.errorMessage) {
        logs.push('[' + formatDateTime(task.updatedAt || new Date().toISOString()) + '] 任务失败: ' + task.errorMessage);
      }

      return logs;
    }

    async function downloadTask(taskId) {
      const task = tasks.find(item => item.id === taskId);
      if (!task || task.status !== 'completed') {
        showToast('任务未完成，暂不可下载', 'info');
        return;
      }
      window.location.href = '/api/deepsearch/tasks/' + taskId + '/download';
    }

    async function deleteTask(taskId) {
      const confirmed = typeof showConfirm === 'function'
        ? await showConfirm('删除后任务记录将不可恢复，确认删除吗？', {
          title: '删除任务',
          okText: '删除',
          cancelText: '取消',
          okButtonType: 'btn-danger',
        })
        : window.confirm('删除后任务记录将不可恢复，确认删除吗？');
      if (!confirmed) return;

      try {
        const response = await fetch('/api/deepsearch/tasks/' + taskId, {
          method: 'DELETE',
          credentials: 'same-origin',
        });
        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.error || '删除失败');
        }
        if (currentDetailTaskId === taskId) {
          closeTaskDetail();
        }
        await loadTasks();
        showToast('任务已删除', 'success');
      } catch (error) {
        console.error('delete task error', error);
        showToast(error instanceof Error ? error.message : '删除失败', 'error');
      }
    }

    function formatDateTime(value) {
      if (!value) return '-';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '-';
      return date.toLocaleString('zh-CN');
    }

    function escapeHtml(str) {
      if (!str) return '';
      const div = document.createElement('div');
      div.textContent = String(str);
      return div.innerHTML;
    }

    function showToast(message, type) {
      if (window.toast && typeof window.toast[type] === 'function') {
        window.toast[type](message);
        return;
      }
      alert(message);
    }

    window.viewTaskDetail = viewTaskDetail;
    window.downloadTask = downloadTask;
    window.deleteTask = deleteTask;
  </script>
` }) %>
