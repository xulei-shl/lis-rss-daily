<!DOCTYPE html>

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <link rel="icon" href="./images/favicon.ico">
    <script src="js/common.js?v=1.1.2"></script>
    <script src="js/jquery.js"></script>
    <style>
        body {
            background-color: #F2F5F7;
        }

        .container {
            width: 462px;
            margin: 0 auto;
            margin-top: 200px;
        }

        .footer-cn {
            width: 462px;
            position: relative;
        }


        .footer-en {
            width: 462px;
            text-align: center;

        }

        .footer-tw {
            width: 462px;
            text-align: center;

        }

        .home-cn {
            position: absolute;
            right: 80px;
            top: 2px;

        }

        .contact {
            /* transform: translateX(10px); */
            margin-left: 108px;
            position: relative;
        }

        .home {

            position: relative;
        }

        .footer div {
            margin-top: 43px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        p {
            font-size: 20px;
            font-family: PingFangSC-Semibold, PingFang SC;
            font-weight: 600;
            color: #87A6DB;
            margin-top: 30px;
            text-align: center;

        }

        a {
            margin-left: 4px;
            font-size: 16px;
            font-family: PingFangSC-Regular, PingFang SC;
            font-weight: 400;
            color: #87A6DB;
            line-height: 16px;
            text-decoration: none;
        }

        /* .isMobile {
            border-top: 1px solid #213e82;
            border-bottom: 1px solid #213e82;
            background-color: #FCFCFC;
            height: 120px;
            margin-top: 150px;
            background-color: gray;
            color: white;
        }

        .ddd {
            text-align: center;
            margin: 50px auto 0 auto;
        } */

        .iconImg {
            width: 20px;
            height: 20px;
            position: absolute;
            top: 1px;
            left: 156px
        }

        .cnImg {
            width: 20px;
            height: 20px;
            position: absolute;
            top: 1px;
            left: -23px
        }
    </style>
</head>
<html>

<body>

    <div class="container">
        <img src="./images/error.png">
        <p class="errCode">服务端出现未知错误了 ！</p>
        <div class="footer-cn">
            <div class="contact">
                <img src="./images/contact.png" class="cnImg">
                <a href="https://service.cnki.net/home">联系我们</a>
            </div>
            <div class="home-cn">
                <img src="./images/home.png" class="cnImg">
                <a href="https://www.cnki.net/" class="zhiwangUrl">中国知网首页</a>
            </div>
        </div>
        <div class="footer-en">
            <div class="home">
                <img class="iconImg" src="./images/home.png">
                <a href="https://oversea.cnki.net/index/" style="margin-left: 32px;">CNKI Homepage</a>
            </div>
        </div>
        <div class="footer-tw">
            <div class="home">
                <img src="./images/home.png" class="iconImg">
                <a href="https://tra.oversea.cnki.net/index/">中國知網首頁</a>
            </div>
        </div>
    </div>
</body>

</html>
<script>
    var url = window.location.href
    var lang = QueryString("lang")
    $(document).ready(function () {
        if (url.indexOf("oversea") !== -1) {
            switch (lang) {
                case "zh-TW":
                    $(".footer-tw").show()
                    $(".footer-cn").hide()
                    $(".footer-en").hide()
                    break;
                case "en-US":
                    $(".footer-en").show()
                    $(".footer-cn").hide()
                    $(".footer-tw").hide()
                    break;
                default:
                    $(".footer-cn").show()
                    $(".footer-en").hide()
                    $(".footer-tw").hide()
                    $(".contact").hide()
                    $(".footer-cn").css("width", "370px")
                    $(".zhiwangUrl").attr('href', "https://chn.oversea.cnki.net/index/")
                    break;
            }

        } else {
            switch (lang) {
                case "zh-TW":
                    $(".footer-tw").show()
                    $(".footer-cn").hide()
                    $(".footer-en").hide()
                    break;
                case "en-US":
                    $(".footer-en").show()
                    $(".footer-cn").hide()
                    $(".footer-tw").hide()
                    break;
                default:
                    $(".footer-cn").show()
                    $(".footer-en").hide()
                    $(".footer-tw").hide()
                    break;
            }
        }


        if (QueryString("isMobile") == "1") {
            $(".footer-cn").hide()
            $(".footer-en").hide()
            $(".footer-tw").hide()
        }
        var ErrMsg = QueryString("ErrMsg")
        ErrMsg = decodeURIComponent(ErrMsg)
        if (ErrMsg) {
            $(".errCode").text(ErrMsg);
        } else {
            $(".errCode").text("服务端出现未知错误了！");
        }


    })

</script>