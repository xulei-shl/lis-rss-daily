# Memos Instance Configuration
# Copy this file to .env and fill in your actual values

# Your Memos instance URL (e.g., https://memos.example.com or http://localhost:5230)
MEMOS_BASE_URL=https://your-memos-instance.com

# Your access token from Memos settings
# Get it: Memos → Settings → Access Tokens → New
# Format: memos_pat_xxxxxxxxxxxx
MEMOS_ACCESS_TOKEN=memos_pat_your_token_here

---

# LIS-RSS API 配置
LIS_RSS_API_URL=https://your-lis-rss.com
LIS_RSS_USERNAME=your_username
LIS_RSS_PASSWORD=your_password

# 主项目统一推送配置
# 不配置 BASE_URL 时，会回退使用 LIS_RSS_API_URL
BASE_URL=https://your-lis-rss.com
# 主项目 CLI API 密钥，用于调用统一推送接口
CLI_API_KEY=your_cli_api_key_here
# 接收 PDF 总结推送的用户 ID，默认 1
PDF_SUMMARY_NOTIFY_USER_ID=1

---

# HiAgent RAG知识库配置
# 工作空间类型（可选，默认 personal）
WorkspaceType=personal
# 工作空间 ID（必填）
WorkspaceID=your_workspace_id
# 知识库 ID（必填）
DatasetID=your_knowledge_id

# HiAgent PDF总结Agent配置

HIAGENT_PDF_URL = https://your-hiagent-pdf-url.com

---

# 企业微信推送配置
# 从企业微信群机器人设置中获取 Webhook Key
# 配置方法：企业微信群 → 群机器人 → 添加机器人 → Webhook
# 是否默认启用脚本内企业微信全文推送
# true: 默认推送；false: 仅在 Telegram /papers 使用 --wechat 时推送
PDF_SUMMARY_PUSH_WECHAT=false
WECHAT_WEBHOOK_KEY=your_wechat_webhook_key_here

---

# Telegran Bot配置#从 @ BotFather获取 Bot  Token
TELEGRAM_BOT_TOKEN=your telegram bot token #可选：允许的用户ID，不设置则不限制
TELEGRAM_USER_ID=your telegram user id
#可选:API地址
TELEGRAM_API_URL=http://localhost:8081
TELEGRAM_API_TIMEOUT-300

#HTTP代理(可选,用于 Telegran API访问)
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
